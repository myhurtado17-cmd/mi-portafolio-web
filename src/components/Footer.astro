---
import { socialLinks } from '../data/social';
import SocialIcons from './icons/SocialIcons.astro';
---

<footer class="py-8 border-t border-card-border text-center text-text-secondary text-sm">
  <div class="container mx-auto px-8 flex flex-col items-center gap-4">
    <p>Diseñado y construido por Marco Yoanis Hurtado Restrepo</p>
    <div class="flex gap-6">
      {socialLinks.map((link) => (
        <a
          href={link.url}
          target={link.url.startsWith('mailto') ? undefined : '_blank'}
          rel={link.url.startsWith('mailto') ? undefined : 'noopener noreferrer'}
          aria-label={link.label}
          class="hover:text-primary hover:-translate-y-0.5 transition-all duration-300"
        >
          <SocialIcons name={link.icon} />
        </a>
      ))}
    </div>
  </div>
</footer>
